{
  "name": "evidence-demo",
  "version": "0.1.0",
  "description": "Local CLI that analyzes a PR against a cloned repo and prints a human-readable evidence report",
  "type": "module",
  "bin": {
    "evidence-demo": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "tsc -p tsconfig.test.json && node --test dist-test/test/**/*.test.js",
    "start": "node dist/cli.js"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "chalk": "^5.4.1",
    "postcss": "^8.5.6",
    "postcss-scss": "^4.0.9"
  },
  "devDependencies": {
    "@types/node": "^22.15.21",
    "typescript": "^5.8.3"
  }
}
